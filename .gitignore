# ---------------------------------------------------------------------------
# Editing sidecars and pre-edit snapshots (2026-07-14)
#
# These are development-tree working artifacts. They are never publishable and
# must not be promoted to C:\x64base. Observed leaking into staging as 815
# untracked files, dominated by dotref.hpp.bak_phase5_* and *.before_mdo_*.
#
# See docs/agents/CURRENT_TARGET.md and AI_PORTAL.md
# ("What C:\x64base Is - and Is Not").
# ---------------------------------------------------------------------------
*.bak
*.bak_*
*.before_mdo_*
*.orig
*.rej
*.save
*.SAVE
*.save.txt

# Backup lanes - working copies, never publishable
/dottalkpp/data/backup/
**/backup/

# ---------------------------------------------------------------------------
# LMDB index environments (2026-07-14)
#
# LMDB is a DERIVED index backend. It is materialized from the CDX container
# via SETLMDB (see src/cli/cmd_setlmdb.cpp: DbArea -> IndexManager ->
# CdxBackend -> LMDB env, stored as <stem>.cdx.d/).
#
# Measured 53 GB in dottalkpp/data/lmdb on 2026-07-14. It must never reach
# C:\x64base or GitHub. Publish the CDX; regenerate the LMDB locally with
# dottalkpp/data/scripts/mcc/mcc_build_x64_lmdb.dts.
# ---------------------------------------------------------------------------
/dottalkpp/data/lmdb/
**/*.cdx.d/

# ---------------------------------------------------------------------------
# Probe and scratch index/table artifacts (2026-07-14)
#
# Generated by ad-hoc probe scripts. Never part of the runtime scaffold or the
# MCC sample set. These leaked into the first PR via directory-level git add.
# The runtime ships its directory STRUCTURE and the MCC/OG data -- not scratch.
# ---------------------------------------------------------------------------
zz_*
**/table.cnx
**/table.cdx
**/table.cdx.meta
*mixed.workspace*
# non-MCC test tables that live inside the sample dirs
/dottalkpp/data/dbf/x64/TEST64.dbf
/dottalkpp/data/dbf/TEST32.dbf
/dottalkpp/data/dbf/TESTVFP.dbf
/dottalkpp/data/dbf/BIGCHAR_TEST.dbf
/dottalkpp/data/dbf/X64SAMPLE.dbf

# Compiled runtime -- the repo ships the scaffold to BUILD the exe, not the exe
/dottalkpp/bin/dottalkpp.exe
**/*.exe

# ---------------------------------------------------------------------------
# MCC extracted originals (2026-07-14)
#
# data/dbf/og is DERIVED. extract_mcc_og.ps1 unpacks it from the canonical
# MyCommunityCollege.zip, which IS published. Publishing both would ship the
# same 84 KB twice and invite them to drift apart.
#
# The zip is the origin. og is a working copy of it.
# ---------------------------------------------------------------------------
/dottalkpp/data/dbf/og/
