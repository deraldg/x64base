  subgraph dotlane["dottalkpp.com publication lane"]
    dotsource["dottalkpp.com source tree\nfocused technical-library source"]:::dot
    dotrepo["deraldg/dottalkpp\nmain + GitHub Actions/Pages history"]:::dot
