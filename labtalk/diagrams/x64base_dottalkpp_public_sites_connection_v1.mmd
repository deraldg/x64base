  truth["Shared upstream authority\nimplementation source + runtime proof + HELP + metadata\ncontracts + CMDHELPCHK + SelfDoc + MDO/manualgen"]:::authority
  review{"Human review and promotion gates\nstatus, provenance, public-content, accessibility, route ownership"}:::gate

  subgraph x64lane["x64base.com publication lane"]
