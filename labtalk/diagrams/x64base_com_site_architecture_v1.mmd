flowchart TB
  classDef authority fill:#e8f4ef,stroke:#26705a,color:#13251f,stroke-width:2px
  classDef process fill:#eef3fb,stroke:#416c9e,color:#172334,stroke-width:2px
  classDef site fill:#fff4dc,stroke:#a46a12,color:#302313,stroke-width:2px
  classDef gate fill:#f3eef8,stroke:#765694,color:#251b30,stroke-width:2px
  classDef output fill:#f7f7f4,stroke:#606a73,color:#1e2429,stroke-width:2px

  truth["Implementation evidence spine\nsource + runtime + HELP + metadata + contracts\nCMDHELPCHK + SelfDoc + proof + MDO/manualgen"]:::authority
  campus["Laboratory Campus evidence\nregistries, labs, cases, lessons, screenshots, proof states"]:::authority
  manuals["Reviewed manuals and diagrams\nversioned sections, crosswalks, architecture visuals"]:::authority

  curation["Public-site curation\nselect, summarize, status-label, link, and attach provenance"]:::process
  source["x64base.com source tree\nNext.js + MDX + public media"]:::process

  subgraph sections["Primary public sections"]
    home["Ecosystem home\nidentity, transparent-engine story, products"]:::site
    engine["Engine documentation\narchitecture, formats, indexes, memos, APIs"]:::site
    products["Product and workbench family\nDotTalk++, DotScript, RelTalk, GUI/TUI"]:::site
    lab["Laboratory Campus\nlearning, cases, evolution, evidence, LMS lane"]:::site
    dev["Development and governance\nproject truth, lanes, DFDs, standards, publication rules"]:::site
    downloads["Curated downloads and links\nsmall public artifacts + routes to deeper artifact room"]:::site
  end

  guard{"Publication gates\npublic-content guard\nno local paths or secrets\nstatus/provenance labels\nroute and link validation"}:::gate
  build["Static build and release metadata\nversioned website source -> reviewed public artifact"]:::process
  github["deraldg/x64base\nwebsite source branch + versioned gh-pages branch"]:::output
  live["x64base.com\nMAIN ECOSYSTEM WEBSITE\nHTTPS GitHub Pages publication"]:::output

  truth --> curation
  campus --> curation
  manuals --> curation
  curation --> source
  source --> home
  source --> engine
  source --> products
  source --> lab
  source --> dev
  source --> downloads
  sections --> guard
  guard --> build
  build --> github
  github --> live
