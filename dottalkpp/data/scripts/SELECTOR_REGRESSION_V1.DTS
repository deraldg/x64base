* ============================================================
* SELECTOR_REGRESSION_V1.DTS
* Purpose:
*   Regression for shared row-selection engine propagation.
* Scope:
*   COUNT / DELETE / RECALL / LOCATE / CONTINUE
* Notes:
*   - Assumes students table exists in XDBF
*   - Uses safe delete/recall pairs to restore state
*   - Avoids permanent destructive drift
* ============================================================

ECHO ON
SET TALK ON

? "===== SELECTOR REGRESSION V1 BEGIN ====="

USE students
SET FILTER TO
SET ORDER TO 0

? "---- BASE COUNT CONTRACT ----"
COUNT
COUNT DELETED
COUNT NOT DELETED
COUNT !DELETED
COUNT FOR LNAME = "ANDERSON"
COUNT WHERE GPA > 3.5
COUNT GPA > 3.5

? "---- FILTER CONTRACT ----"
SET FILTER TO FNAME = "AVA"
COUNT
COUNT FOR GPA > 2.5
COUNT FOR LNAME = "WHITE"
LIST 10
SET FILTER TO

? "---- DELETE / RECALL FOR CONTRACT ----"
COUNT FOR LNAME = "ANDERSON"
DELETE FOR LNAME = "ANDERSON"
COUNT FOR LNAME = "ANDERSON"
COUNT DELETED
RECALL FOR LNAME = "ANDERSON"
COUNT FOR LNAME = "ANDERSON"
COUNT DELETED

? "---- DELETE / RECALL FILTERED ALL CONTRACT ----"
SET FILTER TO FNAME = "AVA"
COUNT
DELETE ALL
COUNT
COUNT DELETED
RECALL ALL
COUNT
COUNT DELETED
SET FILTER TO

? "---- DELETE / RECALL NEXT CONTRACT ----"
TOP
COUNT DELETED
DELETE NEXT 3
COUNT DELETED
RECALL NEXT 3
COUNT DELETED

? "---- LOCATE / CONTINUE FILTERED CONTRACT ----"
SET FILTER TO FNAME = "AVA"
LOCATE FOR LNAME = "WHITE"
TUP
CONTINUE
TUP
SET FILTER TO

? "---- LOCATE / CONTINUE SIMPLE CONTRACT ----"
LOCATE LNAME = "ANDERSON"
TUP
CONTINUE
TUP
CONTINUE
TUP

? "---- LOCATE / CONTINUE ORDERED CONTRACT ----"
SET INDEX TO students
SET ORDER TO TAG LNAME
LOCATE LNAME = "ANDERSON"
TUP
CONTINUE
TUP
CONTINUE
TUP
SET ORDER TO 0

? "---- FILTER + ORDER + COUNT CONTRACT ----"
SET INDEX TO students
SET ORDER TO TAG FNAME
SET FILTER TO FNAME = "AVA"
COUNT
COUNT FOR GPA > 2.5
LIST 10
SET FILTER TO
SET ORDER TO 0

? "---- CURRENT / CURSOR SAFETY CONTRACT ----"
TOP
TUP
LOCATE FOR LNAME = "WHITE"
TUP
CONTINUE
TUP
TOP
TUP
BOTTOM
TUP
CONTINUE
TUP
TOP
TUP

? "---- MIXED COMMAND CHAIN CONTRACT ----"
SET FILTER TO FNAME = "AVA"
LOCATE FOR LNAME = "WHITE"
TUP
DELETE NEXT 1
COUNT DELETED
RECALL NEXT 1
COUNT DELETED
LOCATE FOR LNAME = "WHITE"
TUP
CONTINUE
TUP
SET FILTER TO

? "---- NO TABLE SAFETY CONTRACT ----"
CLOSE
COUNT
LOCATE FOR LNAME = "WHITE"
CONTINUE
DELETE NEXT 1
RECALL NEXT 1

? "---- REOPEN / FINAL SANITY ----"
USE students
SET FILTER TO
SET ORDER TO 0
COUNT
COUNT DELETED
LIST 5

? "===== SELECTOR REGRESSION V1 END ====="
QUIT
