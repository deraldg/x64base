REPLACE NOTES WITH NOTES + " [0213] ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz 0123456789"
REPLACE NOTES WITH NOTES + " [0214] ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz 0123456789"
REPLACE NOTES WITH NOTES + " [0215] ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz 0123456789"
REPLACE NOTES WITH NOTES + " [0216] ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz 0123456789"
REPLACE NOTES WITH NOTES + " [0217] ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz 0123456789"
REPLACE NOTES WITH NOTES + " [0218] ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz 0123456789"
REPLACE NOTES WITH NOTES + " [0219] ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz 0123456789"
REPLACE NOTES WITH NOTES + " [0220] ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz 0123456789"

CLOSE
USE MEMO_SIZE_X64
DISPLAY
TUPLE *

* ---------- 6. LARGE GROWTH BLOCK C ----------
REPLACE NOTES WITH NOTES + " [0301] PACKET-BEGIN :: 1111111111222222222233333333334444444444555555555566666666667777777777888888888899999999990000000000 :: PACKET-END"
REPLACE NOTES WITH NOTES + " [0302] PACKET-BEGIN :: 1111111111222222222233333333334444444444555555555566666666667777777777888888888899999999990000000000 :: PACKET-END"
