REPLACE NOTES WITH NOTES + " [0320] PACKET-BEGIN :: 1111111111222222222233333333334444444444555555555566666666667777777777888888888899999999990000000000 :: PACKET-END"

DISPLAY
TUPLE *

CLOSE
USE MEMO_SIZE_X64
DISPLAY
TUPLE *
COUNT
RECNO

* ---------- 7. CLEAR / REINSERT ----------
REPLACE NOTES WITH ""
DISPLAY
TUPLE *

CLOSE
USE MEMO_SIZE_X64
DISPLAY
TUPLE *

REPLACE NOTES WITH "AFTER-CLEAR-REINSERT"
REPLACE NOTES WITH NOTES + " [R001] First append after clear."
REPLACE NOTES WITH NOTES + " [R002] Second append after clear."
REPLACE NOTES WITH NOTES + " [R003] Third append after clear."
REPLACE NOTES WITH NOTES + " [R004] Fourth append after clear."
REPLACE NOTES WITH NOTES + " [R005] Fifth append after clear."

DISPLAY
TUPLE *

CLOSE
USE MEMO_SIZE_X64
DISPLAY
TUPLE *
STRUCT
FIELDS

SET TALK ON