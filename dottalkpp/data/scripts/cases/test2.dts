* ============================================================
* MCC_SHAKEDOWN.DTS - My Community College DBFs
* CALC Function/Operator Test Suite (expanded)
*
* Rules (based on current engine behavior):
*  - Use CALC for functions.
*  - If an expression contains "=", ">=", "<=" then wrap it:
*        CALC ( ... )
*    so it does NOT fall into CALCWRITE routing.
*  - Keep BOOLEAN for field-only predicates (no function calls).
* ============================================================

SET ECHO ON
ECHO ===== DotTalk++ MCC SHAKE-DOWN START =====

COLOR DEFAULT
SCHEMAS CLOSE
SCHEMAS OPEN DBF
SCHEMAS

* ------------------------------------------------------------
ECHO ===== CALC: LITERALS / ARITH / PRECEDENCE =====
CALC 1
CALC 1 + 2
CALC 10 - 3
CALC 6 * 7
CALC 8 / 2
CALC (1 + 2) * 3
CALC 1 + 2 * 3
CALC 7 / 2
CALC 7.0 / 2
CALC 0 - 5
CALC -5 + 2
CALC 1 + -2
CALC (0 - 2) * 3

* OPTIONAL: error-path sanity (uncomment when you want noise)
* CALC 1 / 0

* ------------------------------------------------------------
ECHO ===== CALC: BOOLEAN OPS / COMPARISONS (PARENTHESIZE WHEN USING '=') =====

* basic compares (no '=' token)
CALC (1 < 2)
CALC (2 > 1)

* equality / inequality (MUST be parenthesized)
CALC (1 = 1)
CALC (1 = 2)

* >= and <= (contain '=' so MUST be parenthesized)
CALC (2 >= 2)
CALC (2 <= 2)
CALC (2 >= 3)
CALC (2 <= 1)

* logic
CALC (NOT (1 = 2))
CALC ((1 = 1) AND (2 = 2))
CALC ((1 = 1) OR (1 = 2))
CALC ((1 = 2) OR (2 = 2))

* precedence sanity
CALC ((1 + 2 * 3) = 7)
CALC (((1 + 2) * 3) = 9)

* if "<>" isn't supported, keep as a canary (commented by default)
* CALC (1 <> 2)

* ------------------------------------------------------------
ECHO ===== CALC: CLOCK / DATE-TIME (NO DBF REQUIRED) =====
CALC DATE()
CALC TODAY()
CALC TIME()
CALC NOW()
CALC DATETIME()

* identity sanity (wrap '=')
CALC (DATE() = TODAY())
CALC (NOW() = DATETIME())

* date +/- days
CALC DATE() + 2
CALC DATE() - 2
CALC ( (DATE() + 2) > DATE() )
CALC ( (DATE() - 2) < DATE() )

* CTOD parsing (string/numeric)
CALC CTOD(2000-01-01)
CALC CTOD("2000/01/01")
CALC CTOD(20000101)

* CTOD comparisons + arithmetic (wrap '=')
CALC (CTOD(2000-01-01) = 20000101)
CALC (CTOD("2000/01/01") = 20000101)
CALC (CTOD(20000101) = 20000101)
CALC CTOD(2000-01-01) + 1
CALC CTOD(2000-01-01) - 1
CALC ((CTOD(2000-01-01) + 1) = 20000102)
CALC ((CTOD(2000-01-01) - 1) = 19991231)

* OPTIONAL: DTOC/DTOS if registered
* CALC DTOC(DATE())
* CALC DTOS(DATE())
* CALC (CTOD(DTOC(DATE())) = DATE())
* CALC (CTOD(DTOS(DATE())) = DATE())

* OPTIONAL: date parts if registered
* CALC YEAR(DATE())
* CALC MONTH(DATE())
* CALC DAY(DATE())
* CALC DOW(DATE())

* ------------------------------------------------------------
ECHO ===== BASIC COMMAND SANITY =====
HELP
AREA

* ------------------------------------------------------------
ECHO ===== BUILDING =====
SELECT BUILDING
AREA
STRUCT
COUNT
LIST 5
TUP

