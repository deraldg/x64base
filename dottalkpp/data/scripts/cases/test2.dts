* ------------------------------------------------------------
ECHO ===== CALC: FIELD READS / TYPE PATHS (STUDENTS) =====
SELECT STUDENTS
LIST 1
TUP SID
TUP LNAME
TUP FNAME
TUP DOB
TUP ENROLL_D
TUP GPA
TUP EMAIL

CALC SID
CALC LNAME
CALC FNAME
CALC DOB
CALC ENROLL_D
CALC GPA
CALC EMAIL

* numeric ops on field
ECHO -- NUMERIC OPS (GPA)
CALC GPA + 1
CALC GPA - 1
CALC GPA * 2
CALC GPA / 2
CALC (GPA > 3)
CALC ((GPA >= 2) AND (GPA <= 4))   && uses '=' inside >=/<= so it is already parenthesized

* OPTIONAL numeric builtins (uncomment once you confirm these are registered)
* CALC ABS(-5)
* CALC INT(3.9)
* CALC ROUND(3.14159, 2)
* CALC MOD(7, 3)
* CALC SQRT(9)
* CALC POW(2, 8)
* CALC MIN(2, 9)
* CALC MAX(2, 9)

* ------------------------------------------------------------
ECHO ===== CALC: DATE FIELDS + DATE ALGEBRA (STUDENTS) =====
SELECT STUDENTS
LIST 1

CALC DOB
CALC ENROLL_D

* operator path
CALC DOB + 1
CALC DOB - 1
CALC ((DOB + 1) > DOB)
CALC ((DOB - 1) < DOB)

* DATEADD / DATEDIFF
CALC DATEADD(DOB, 30)
CALC DATEADD(DOB, -30)
CALC DATEADD(DATE(), 30)
CALC DATEADD(DATE(), -30)
CALC DATEDIFF(DATE(), DOB)
CALC DATE() - DOB
CALC (DATEDIFF(DATE(), DOB) = (DATE() - DOB))
CALC (DATEDIFF(DATE(), DOB) > 0)

* OPTIONAL: ensure ENROLL_D is after DOB (wrap '=' not needed; it's '>')
CALC (ENROLL_D > DOB)

* ------------------------------------------------------------
ECHO ===== CALC: STRING BUILTINS (FIELD + LITERAL) =====
SELECT STUDENTS
LIST 1

* field-based (your existing working path)
CALC TUPLE UPPER(LNAME)
CALC TUPLE LOWER(LNAME)
CALC TUPLE PROPER(LNAME)
CALC TUPLE LEFT(LNAME, 3)
CALC TUPLE RIGHT(FNAME, 2)
CALC TUPLE ALLTRIM(EMAIL)

* literal-based (wrap '=')
CALC (UPPER("aBc") = "ABC")
CALC (LOWER("aBc") = "abc")
CALC (PROPER("joHN") = "John")
CALC (LEFT("ABCDE", 3) = "ABC")
CALC (RIGHT("ABCDE", 2) = "DE")
CALC (ALLTRIM("  hi  ") = "hi")

* trim family (OPTIONAL)
* CALC TRIM("  hi  ")
* CALC LTRIM("  hi  ")
* CALC RTRIM("  hi  ")
* CALC (TRIM("  hi  ") = "hi")
* CALC (LTRIM("  hi  ") = "hi  ")
* CALC (RTRIM("  hi  ") = "  hi")

* OPTIONAL: string extras (uncomment if registered)
* CALC LEN("ABCDE")
* CALC LEN(EMAIL)
* CALC SUBSTR("ABCDE", 2, 3)           && "BCD"
* CALC AT("CD", "ABCDE")               && 3
* CALC RAT("A", "BANANA")              && last A position
* CALC REPLICATE("x", 5)               && "xxxxx"
* CALC SPACE(3)                        && "   "
* CALC STRTRAN("BANANA","NA","*")      && if you have it

* ------------------------------------------------------------
ECHO ===== BOOLEAN / PREDICATE (FIELD-ONLY COVERAGE) =====
* IMPORTANT: BOOLEAN stays field-only; no DATE(), CTOD(), UPPER(), etc.
SELECT STUDENTS
LIST 1
BOOLEAN GPA > 3
BOOLEAN GPA < 3
BOOLEAN GPA >= 2 AND GPA <= 4
BOOLEAN LNAME = "Qui"
BOOLEAN LNAME = "Davis" OR LNAME = "Qui"
BOOLEAN GPA > 0 AND GPA < 10

* ------------------------------------------------------------
ECHO ===== LOCATE SMOKE (STUDENTS) =====
SELECT STUDENTS
LOCATE FOR LNAME = DAVIS
TUP
LOCATE FOR LNAME = TAYLOR
TUP

* ------------------------------------------------------------
ECHO ===== CALCWRITE: REVERSIBLE WRITE TEST (GPA += .01 then -= .01) =====
* NOTE: verify via TUP GPA (not CALC GPA)
SELECT STUDENTS
LOCATE FOR LNAME = TAYLOR
LIST 1
TUP GPA
CALC GPA = GPA + 0.01
TUP GPA
CALC GPA = GPA - 0.01
TUP GPA

* ------------------------------------------------------------
ECHO ===== COLOR SANITY =====
COLOR GREEN
COLOR AMBER
COLOR DEFAULT

ECHO ===== CLEAN SHUTDOWN =====
SCHEMAS
SCHEMAS CLOSE
ECHO ===== DotTalk++ MCC SHAKE-DOWN END =====
QUIT
