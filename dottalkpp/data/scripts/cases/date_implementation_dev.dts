* ============================================================
* MCC_SHAKEDOWN.DTS - My Community College DBFs
* Date Implementation Tests
* ============================================================

SET ECHO OFF
ECHO ===== DotTalk++ MCC SHAKE-DOWN START =====

COLOR DEFAULT
SCHEMAS CLOSE
SCHEMAS OPEN DBF
SCHEMAS

ECHO ===== CLOCK / DATE-TIME (no DBF required) =====
CALC DATE()
CALC TODAY()
CALC TIME()
CALC NOW()
CALC DATETIME()
CALC DATE() + 2
CALC DATE() - 2
CALC CTOD(2000-01-01)
CALC CTOD("2000/01/01")
CALC CTOD(20000101)

ECHO ===== BASIC COMMAND SANITY =====
HELP
AREA

*  ------------------------------------------------------------
ECHO ===== BUILDING =====
SELECT BUILDING
AREA
STRUCT
COUNT
LIST 5
TUP

ECHO ===== ROOMS =====
SELECT ROOMS
AREA
STRUCT
COUNT
LIST 5
TUP

