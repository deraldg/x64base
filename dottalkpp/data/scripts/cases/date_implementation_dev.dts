COUNT
LIST 5
TUP

* ------------------------------------------------------------
ECHO ===== DATE FIELDS + DATE ALGEBRA (STUDENTS) =====
SELECT STUDENTS
LIST 1
TUP DOB
TUP ENROLL_D
CALC DOB
CALC DOB + 1
CALC DOB - 1
CALC DATEADD(DOB, 30)
CALC DATEADD(DOB, -30)
CALC DATE() + 30
CALC DATE() - 30

* If your DATEDIFF / date-date is enabled, these should print an integer day count:
CALC DATEDIFF(DATE(), DOB)
CALC DATE() - DOB

* ------------------------------------------------------------
ECHO ===== BOOLEAN / PREDICATE (use BOOLEAN for >= / <=) =====
SELECT STUDENTS
LIST 1
BOOLEAN GPA > 3
BOOLEAN GPA < 3
BOOLEAN GPA >= 2 AND GPA <= 4

* ------------------------------------------------------------
ECHO ===== STRING BUILTINS (CALC TUPLE ...) =====
* Expected examples (should print strings* if you see blank/.F., that’s a regression to fix)
SELECT STUDENTS
LIST 1
CALC TUPLE UPPER(LNAME)
CALC TUPLE LOWER(LNAME)
CALC TUPLE PROPER(LNAME)
CALC TUPLE LEFT(LNAME, 3)
CALC TUPLE RIGHT(FNAME, 2)
CALC TUPLE ALLTRIM(EMAIL)

* ------------------------------------------------------------
ECHO ===== LOCATE SMOKE (STUDENTS) =====
SELECT STUDENTS
LOCATE FOR LNAME = DAVIS
TUP
LOCATE FOR LNAME = TAYLOR
TUP

* ------------------------------------------------------------
ECHO ===== REVERSIBLE WRITE TEST (GPA += .01 then -= .01) =====
* NOTE: verify via TUP GPA (not CALC GPA)
SELECT STUDENTS
LIST 1
TUP GPA
CALC GPA = GPA + 0.01
TUP GPA
CALC GPA = GPA - 0.01
TUP GPA

* ------------------------------------------------------------
ECHO ===== COLOR SANITY =====
COLOR GREEN
COLOR AMBER
COLOR DEFAULT

ECHO ===== CLEAN SHUTDOWN =====
SCHEMAS
SCHEMAS CLOSE
ECHO ===== DotTalk++ MCC SHAKE-DOWN END =====
* QUIT
