echo REL JOIN/ENUM regression mini-suite (12 tests)

echo TEST 01: clean start + open DBF schemas
SCHEMAS CLOSE
SCHEMAS OPEN DBF

echo TEST 02: select STUDENTS + locate known SID
SELECT STUDENTS
LOCATE FOR SID = 50000010
RECNO

echo TEST 03: reset relations + build chain STUDENTS->ENROLL->CLASSES->TASSIGN->TEACHERS
SET RELATIONS CLEAR ALL
SET RELATIONS ADD STUDENTS ENROLL ON SID
SET RELATIONS ADD ENROLL CLASSES ON CLS_ID
SET RELATIONS ADD CLASSES TASSIGN ON CLS_ID
SET RELATIONS ADD TASSIGN TEACHERS ON TID
REL REFRESH

echo TEST 04: REL LIST should show ENROLL matches (expect: 2 for SID=50000010)
REL LIST

echo TEST 05: cursor should be stable across refresh/list (RECNO unchanged)
RECNO
REL REFRESH
RECNO

echo TEST 06: REL JOIN ONE should emit exactly 1 row (historical behavior)
REL JOIN ONE LIMIT 0 TUPLE STUDENTS.SID, ENROLL.CLS_ID, CLASSES.CID, TEACHERS.LNAME

echo TEST 07: REL JOIN should enumerate like ENUM (expect: >1 rows; known dataset: 5 rows here)
REL JOIN LIMIT 0 TUPLE STUDENTS.SID, ENROLL.CLS_ID, CLASSES.CID, TEACHERS.LNAME

echo TEST 08: REL ENUM should match REL JOIN row-for-row for the same projection
REL ENUM LIMIT 0 TUPLE STUDENTS.SID, ENROLL.CLS_ID, CLASSES.CID, TEACHERS.LNAME

echo TEST 09: DISTINCT should collapse projection-duplicates (expect: 3 rows here: 2 teachers ENGL170 + 1 for ENGL290)
REL JOIN DISTINCT LIMIT 0 TUPLE STUDENTS.SID, ENROLL.CLS_ID, CLASSES.CID, TEACHERS.LNAME

echo TEST 10: include CLASSES.SEC to make rows unique (expect: 5 rows; DISTINCT should not reduce)
REL JOIN LIMIT 0 TUPLE STUDENTS.SID, ENROLL.CLS_ID, CLASSES.CID, CLASSES.SEC, TEACHERS.LNAME
REL JOIN DISTINCT LIMIT 0 TUPLE STUDENTS.SID, ENROLL.CLS_ID, CLASSES.CID, CLASSES.SEC, TEACHERS.LNAME

echo TEST 11: LIMIT should cap rows (expect: exactly 2 rows)
REL JOIN LIMIT 2 TUPLE STUDENTS.SID, ENROLL.CLS_ID, CLASSES.CID, TEACHERS.LNAME

echo TEST 12: explicit chain path should work + REL LIST ALL should not crash
REL JOIN ENROLL CLASSES TASSIGN TEACHERS LIMIT 0 TUPLE STUDENTS.SID, STUDENTS.LNAME, ENROLL.CLS_ID, CLASSES.SEC, TEACHERS.LNAME
REL LIST ALL

echo DONE
