ECHO ============================================================
ECHO MCC - Build full relations graph (CNX-backed)
ECHO ============================================================

SCHEMAS CLOSE
SCHEMAS OPEN DBF

SELECT STUDENTS
SET RELATIONS CLEAR ALL

ECHO --- Student-centric spine ---
SET RELATIONS ADD STUDENTS ENROLL   ON SID
SET RELATIONS ADD ENROLL   CLASSES  ON CLS_ID

ECHO --- Class lookups ---
SET RELATIONS ADD CLASSES  COURSES  ON CID
SET RELATIONS ADD COURSES  DEPT     ON DEPT_ID

SET RELATIONS ADD CLASSES  TERMS    ON TERM
SET RELATIONS ADD CLASSES  ROOMS    ON ROOM
SET RELATIONS ADD ROOMS    BUILDING ON BLDG

SET RELATIONS ADD CLASSES  TEACHERS ON TID
SET RELATIONS ADD TEACHERS DEPT     ON DEPT_ID

ECHO --- TA assignment chain ---
SET RELATIONS ADD CLASSES  TASSIGN  ON CLS_ID
SET RELATIONS ADD TASSIGN  TEACHERS ON TID

ECHO --- Major history + current major ---
SET RELATIONS ADD STUDENTS STUD_MAJ ON SID
SET RELATIONS ADD STUD_MAJ MAJORS   ON MAJOR
SET RELATIONS ADD MAJORS   DEPT     ON DEPT_ID

SET RELATIONS ADD STUDENTS MAJORS   ON MAJOR

REL REFRESH

ECHO --- Proof / snapshot ---
REL LIST ALL
