SET ECHO OFF
* ============================================================
* MCC_CALC_DATE_REPLACE_SHAKEDOWN.DTS
* Focus: STUDENTS.DOB + STUDENTS.ENROLL_D
* - CALC date functions on real DBF date fields
* - REPLACE date fields using DATE()/DATEADD()/field->field copy
* - Restores original values at the end (for SID 50000001)
* ============================================================

ECHO ===== DATE/REPLACE SHAKE-DOWN START =====
COLOR DEFAULT

USE STUDENTS
SELECT STUDENTS

* Anchor on a stable record
TOP
LOCATE FOR SID = 50000001
RECNO
TUPLE
* Force known-good baseline for repeatable runs
* Make sure MULTIREP doesn't regress	 (unquoted raw data char replacement)
MULTIREP LNAME WITH Washington, FNAME WITH George, DOB WITH 19560213, GENDER WITH X, ENROLL_D WITH 20240922

ECHO -- Anchor record BEFORE --
LIST 2
TUP DOB
TUP ENROLL_D

ECHO ===== CALC: read date fields + comparisons =====
CALC DOB
CALC ENROLL_D
CALC DATE()
CALC TODAY()

CALC (ENROLL_D > DOB)
CALC (DATE() >= DOB)
CALC (DOB <= DATE())

ECHO ===== DIAGNOSTIC: function-vs-literal compares =====
CALC (DATE() > 20000101)
CALC (DATE() > "20000101")
CALC (DATE() > CTOD(20000101))
* Optional (if CTOD also accepts quoted):
CALC (DATE() > CTOD("20000101"))

CALC (20000101 < DATE())
CALC (DOB < DATE())
* reverse
CALC (20000101 > DATE())
CALC (DOB > DATE())

CALC CTOD("2000-01-01")
CALC (CTOD("2000-01-01") + 1)
CALC (CTOD("2000-01-01") + 1 = CTOD("2000-01-02"))


ECHO ===== REGRESSION SANITY CHECKS =====
CALC (DATE() = DATE())
CALC (DATE() = TODAY())
CALC (1 = 1)

* Compare as strings
CALC (DOB = "19560213")
CALC (ENROLL_D = "20250710")

* Numeric/date mixed compare
CALC (DOB = 19560213)
CALC (ENROLL_D = 20250710)

ECHO ===== CALC: DATEADD / DATEDIFF over fields =====
CALC DATEADD(DOB, 30)
CALC DATEADD(ENROLL_D, -30)
CALC DATEDIFF(ENROLL_D, DOB)
CALC DATEDIFF(DATE(), DOB)

ECHO ===== REPLACE: DOB := DATE() then restore =====
REPLACE DOB WITH DATE()
TUP DOB
REPLACE DOB WITH 20050925
TUP DOB

ECHO ===== REPLACE: DOB := ENROLL_D (field->field) then restore =====
REPLACE DOB WITH ENROLL_D
TUP DOB
REPLACE DOB WITH 20050925
TUP DOB

ECHO ===== REPLACE: ENROLL_D := DATEADD(DATE(), 10) then restore =====
REPLACE ENROLL_D WITH DATEADD(DATE(), 10)
TUP ENROLL_D
REPLACE ENROLL_D WITH 20250710
TUP ENROLL_D

ECHO ===== REPLACE: DOB := DATEADD(DOB, 1) then restore =====
REPLACE DOB WITH DATEADD(DOB, 1)
TUP DOB
REPLACE DOB WITH 20050925
TUP DOB

ECHO ===== Post-write verification =====
TUP DOB
TUP ENROLL_D
CALC DATEDIFF(ENROLL_D, DOB)
CALC (DOB = "20050925")
CALC (ENROLL_D = "20250710")

* OPTIONAL negative test (leave commented unless you are actively testing blank-date handling)
TUP DOB
* REPLACE DOB WITH 00000000
REPLACE DOB WITH "        "
CALC DATEDIFF(DATE(), DOB)

* REPLACE DOB WITH 20050925

ECHO ===== STRING SHAKEDOWN FOR REGRESSION TESTING =====
SET VAR TMP_NAME = LincolnTown
SHOW VAR
GOTO 50
TUP

REPLACE LNAME WITH GRIMWOOD
REPLACE FNAME WITH DERALD
TUP

REPLACE LNAME WITH RIGHT(FNAME,5)
TUP

REPLACE FNAME WITH CONCAT(ABC,DEF,GHI)
TUP

REPLACE FNAME WITH LEFT(RIGHT(FNAME,4),2)
TUP

REPLACE FNAME WITH Derald
REPLACE FNAME WITH RIGHT(LEFT(FNAME,5),2)
TUP

REPLACE FNAME WITH DeraldRaymondGrimwoodJunior
TUP

CALC LEFT(FNAME,10) && (should show 10 chars, not 9)
CALC RIGHT(LEFT(FNAME,10),7)

LEFT RIGHT(FNAME,10),7
LEFT FNAME,4
RIGHT FNAME,4

REPLACE FNAME WITH RIGHT(LEFT(FNAME,10),7)
TUP

REPLACE FNAME WITH RIGHT(TRIM(FNAME),5)
TUP

REPLACE FNAME WITH &TMP_NAME
REPLACE LNAME WITH &TMP_NAME
TUP

ECHO ===== VAL() REGRESSION =====
CALC VAL("123")
CALC (VAL("123") = 123)
CALC (VAL("123") = VAL(123))
CALC (VAL("123") = VAL("123"))

CALC LEFT(FNAME,10) && (should show 10 chars, not 9)
CALC RIGHT(LEFT(FNAME,10),7)
TUP

MULTIREP LNAME WITH Washington, FNAME WITH George, DOB WITH 19560213, GENDER WITH X, ENROLL_D WITH 20240922
TUP
ECHO ===== DATE/REPLACE SHAKE-DOWN END =====
