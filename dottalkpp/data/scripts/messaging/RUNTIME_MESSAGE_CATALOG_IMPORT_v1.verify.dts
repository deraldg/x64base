* ============================================================
* RUNTIME_MESSAGE_CATALOG_IMPORT_v1.verify.dts
* Purpose:
*   Read back the full runtime message-catalog snapshot and prove locale
*   routing over the active messaging lane.
* ============================================================

SET ECHO OFF
ECHO ===== RUNTIME MESSAGE CATALOG VERIFY START =====

WORKSPACE CLOSE ALL
CLOSE ALL
REL CLEAR ALL

SETPATH DBF MESSAGING
SETPATH INDEXES INDEXES/MESSAGING
SETPATH LMDB LMDB/MESSAGING

SELECT 0
USE SYSTEM_MESSAGES
ECHO SYSTEM_MESSAGES TOTAL:
COUNT ALL

SELECT 1
USE SYSTEM_MESSAGE_TEXT
ECHO SYSTEM_MESSAGE_TEXT TOTAL:
COUNT ALL

ECHO EN-US SAMPLE:
LOCATE FOR LOCALE = "en-US"
TUP
ECHO DE SAMPLE:
LOCATE FOR LOCALE = "de"
TUP
ECHO ES SAMPLE:
LOCATE FOR LOCALE = "es"
TUP
ECHO FR SAMPLE:
LOCATE FOR LOCALE = "fr"
TUP
ECHO IT SAMPLE:
LOCATE FOR LOCALE = "it"
TUP

SET LANGUAGE TO en-US
SET MESSAGE CATALOG CHECK
SET MESSAGE EMIT HELP_HINT_COMMAND ARG command HELP
SET MESSAGE EMIT MSGMGR_STATUS_TITLE

SET LANGUAGE TO es
SET MESSAGE EMIT MSGMGR_STATUS_TITLE

SET LANGUAGE TO fr
SET MESSAGE EMIT MSGMGR_STATUS_TITLE

SET LANGUAGE TO de
SET MESSAGE EMIT MSGMGR_STATUS_TITLE

SET LANGUAGE TO it
SET MESSAGE EMIT MSGMGR_STATUS_TITLE

SET LANGUAGE TO en-US

ECHO ===== RUNTIME MESSAGE CATALOG VERIFY END =====
