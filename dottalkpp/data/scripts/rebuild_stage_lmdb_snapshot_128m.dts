ECHO .
ECHO ===== DATADICT LANE =====
SETPATH DBF datadict
SETPATH INDEXES indexes\datadict
SETPATH LMDB lmdb\datadict
WORKSPACE CLOSE
WORKSPACE OPEN DBF CDX

SELECT DATA_DICTIONARY_EVIDENCE_RECORDS
SET INDEX TO DATA_DICTIONARY_EVIDENCE_RECORDS.cdx
BUILDLMDB CLEAN YES

SELECT DATA_DICTIONARY_GATE_RECORDS
SET INDEX TO DATA_DICTIONARY_GATE_RECORDS.cdx
BUILDLMDB CLEAN YES

SELECT DATA_DICTIONARY_OBJECT_ATTRIBUTES
SET INDEX TO DATA_DICTIONARY_OBJECT_ATTRIBUTES.cdx
BUILDLMDB CLEAN YES

SELECT DATA_DICTIONARY_OBJECTS
SET INDEX TO DATA_DICTIONARY_OBJECTS.cdx
BUILDLMDB CLEAN YES

SELECT DATA_DICTIONARY_RELATION_EDGES
SET INDEX TO DATA_DICTIONARY_RELATION_EDGES.cdx
BUILDLMDB CLEAN YES

SELECT DATA_DICTIONARY_RUNS
SET INDEX TO DATA_DICTIONARY_RUNS.cdx
