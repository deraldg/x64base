* ============================================================
* rebuild_stage_lmdb_snapshot_128m.dts
*
* Purpose:
*   Rebuild staged LMDB payloads from committed CDX containers.
*
* Snapshot policy:
*   - Git staging keeps CDX containers.
*   - Git staging does NOT keep LMDB payload files.
*   - This script recreates LMDB envs at the default 128 MiB size.
*   - Lane setup is inlined here because DotScript path resolution
*     inside data\scripts does not reliably find top-level data\*.dts.
*
* Maintenance rule:
*   Update the lane sections below whenever a staged snapshot adds,
*   removes, or renames a CDX-backed table.
*
* Current note:
*   The staged metadata lane currently keeps only SYSCMD.cdx,
*   so only that LMDB env is rebuilt from stage alone.
*
* Usage:
*   DO scripts\rebuild_stage_lmdb_snapshot_128m
* ============================================================

SET ECHO ON

ECHO ============================================================
ECHO REBUILD STAGED LMDB SNAPSHOT FROM CDX CONTAINERS
ECHO ============================================================

ECHO .
ECHO ===== X64 LANE =====
SETPATH DBF dbf\x64
SETPATH INDEXES indexes\x64
SETPATH LMDB lmdb\x64
WORKSPACE CLOSE
WORKSPACE OPEN DBF CDX

SELECT BUILDING
SET INDEX TO BUILDING.cdx
BUILDLMDB CLEAN YES

SELECT CLASSES
SET INDEX TO CLASSES.cdx
BUILDLMDB CLEAN YES

SELECT COURSES
SET INDEX TO COURSES.cdx
BUILDLMDB CLEAN YES

SELECT DEPT
SET INDEX TO DEPT.cdx
BUILDLMDB CLEAN YES

SELECT ENROLL
SET INDEX TO ENROLL.cdx
BUILDLMDB CLEAN YES

SELECT MAJORS
SET INDEX TO MAJORS.cdx
BUILDLMDB CLEAN YES

SELECT ROOMS
SET INDEX TO ROOMS.cdx
BUILDLMDB CLEAN YES

SELECT STUD_MAJ
SET INDEX TO STUD_MAJ.cdx
BUILDLMDB CLEAN YES

SELECT STUDENTS
SET INDEX TO STUDENTS.cdx
BUILDLMDB CLEAN YES

SELECT TASSIGN
SET INDEX TO TASSIGN.cdx
BUILDLMDB CLEAN YES

SELECT TEACHERS
SET INDEX TO TEACHERS.cdx
BUILDLMDB CLEAN YES

SELECT TERMS
SET INDEX TO TERMS.cdx
BUILDLMDB CLEAN YES

ECHO .
ECHO ===== HELP LANE =====
