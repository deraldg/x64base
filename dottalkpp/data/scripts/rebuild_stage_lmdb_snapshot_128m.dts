SET INDEX TO COMMANDS.cdx
BUILDLMDB CLEAN YES

SELECT HELP_ARTIFACT_LOCALE
SET INDEX TO HELP_ARTIFACT_LOCALE.cdx
BUILDLMDB CLEAN YES

SELECT HELP_LINE_LOCALE
SET INDEX TO HELP_LINE_LOCALE.cdx
BUILDLMDB CLEAN YES

SELECT HELP_SECTION_LOCALE
SET INDEX TO HELP_SECTION_LOCALE.cdx
BUILDLMDB CLEAN YES

SELECT HELP_TOPIC_LOCALE
SET INDEX TO HELP_TOPIC_LOCALE.cdx
BUILDLMDB CLEAN YES

ECHO .
ECHO ===== LOCALE LANE =====
SETPATH DBF locale
SETPATH INDEXES indexes\locale
SETPATH LMDB lmdb\locale
WORKSPACE CLOSE
WORKSPACE OPEN DBF CDX

SELECT SYSTEM_LOCALE_FALLBACK
SET INDEX TO SYSTEM_LOCALE_FALLBACK.cdx
BUILDLMDB CLEAN YES

SELECT SYSTEM_LOCALES
SET INDEX TO SYSTEM_LOCALES.cdx
BUILDLMDB CLEAN YES

ECHO .
ECHO ===== MANUALS LANE =====
SETPATH DBF manuals
SETPATH INDEXES indexes\manuals
SETPATH LMDB lmdb\manuals
WORKSPACE CLOSE
WORKSPACE OPEN DBF CDX

SELECT MANANCHOR
SET INDEX TO MANANCHOR.cdx
BUILDLMDB CLEAN YES

SELECT MANAPPX
SET INDEX TO MANAPPX.cdx
BUILDLMDB CLEAN YES

SELECT MANHASH
SET INDEX TO MANHASH.cdx
BUILDLMDB CLEAN YES

SELECT MANMEDIA
SET INDEX TO MANMEDIA.cdx
BUILDLMDB CLEAN YES

SELECT MANPUB
SET INDEX TO MANPUB.cdx
BUILDLMDB CLEAN YES

SELECT MANREVIEW
SET INDEX TO MANREVIEW.cdx
BUILDLMDB CLEAN YES

SELECT MANRUN
SET INDEX TO MANRUN.cdx
BUILDLMDB CLEAN YES

SELECT MANSECTION
SET INDEX TO MANSECTION.cdx
BUILDLMDB CLEAN YES

ECHO .
ECHO ===== MESSAGING LANE =====
SETPATH DBF messaging
SETPATH INDEXES indexes\messaging
SETPATH LMDB lmdb\messaging
WORKSPACE CLOSE
WORKSPACE OPEN DBF CDX

SELECT SYSTEM_MESSAGE_TEXT
SET INDEX TO SYSTEM_MESSAGE_TEXT.cdx
