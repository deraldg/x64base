SELECT DDARTIF
SET INDEX TO DDARTIF.cdx
BUILDLMDB CLEAN YES

SELECT DDATTR
SET INDEX TO DDATTR.cdx
BUILDLMDB CLEAN YES

SELECT DDBASE
SET INDEX TO DDBASE.cdx
BUILDLMDB CLEAN YES

SELECT DDEDGE
SET INDEX TO DDEDGE.cdx
BUILDLMDB CLEAN YES

SELECT DDEVID
SET INDEX TO DDEVID.cdx
BUILDLMDB CLEAN YES

SELECT DDGATE
SET INDEX TO DDGATE.cdx
BUILDLMDB CLEAN YES

SELECT DDOBJECT
SET INDEX TO DDOBJECT.cdx
BUILDLMDB CLEAN YES

SELECT DDPROFILE
SET INDEX TO DDPROFILE.cdx
BUILDLMDB CLEAN YES

SELECT DDREVIEW
SET INDEX TO DDREVIEW.cdx
BUILDLMDB CLEAN YES

SELECT DDRUN
SET INDEX TO DDRUN.cdx
BUILDLMDB CLEAN YES

SELECT DDSOURCE
SET INDEX TO DDSOURCE.cdx
BUILDLMDB CLEAN YES

ECHO .
ECHO ===== REBUILD COMPLETE =====
ECHO Recreated staged LMDB payloads from committed CDX containers.
ECHO Default mapsize used: 128 MiB.
ECHO ============================================================
