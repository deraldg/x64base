ECHO -- Phase 1: SET VAR! typed/evaluated values - need to test memmos with vars too --
SET VAR! n = 1
SET VAR! step = 1
SET VAR! cutoff = CTOD("2026-01-01")
SET VAR! who = "Grimwood"
SET VAR! s = "20260101"

SHOW VAR
SHOW VAR n
SHOW VAR cutoff
SHOW VAR who
SHOW VAR s

ECHO -- Phase 3: true counter loop (n should step up) --
LOOP 5
  ECHO n=&n
  SET VAR! n = (&n + &step)
* insert your commands here
  CONCAT(&cutoff,"Accumate") 
* end insert
ENDLOOP
  replace NOTES with cutoff
SHOW VAR n
SHOQ VAR cutoff
