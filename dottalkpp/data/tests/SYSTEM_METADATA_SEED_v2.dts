* ------------------------------------------------------------
* HELP TEXT MEMOS
* ------------------------------------------------------------
USE SYSTEM_HELP_TEXT

APPEND
REPLACE HELP_TEXT_ID WITH "HT_HELP_SUMMARY"
REPLACE OWNER_KIND WITH "command"
REPLACE OWNER_NAME WITH "HELP"
REPLACE TEXT_KIND WITH "summary"
REPLACE SEQ WITH 10
