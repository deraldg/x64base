REPLACE NOTES WITH "Memo proof row for SYSTEM_HELP_TEXT.TEXT_BODY."

APPEND
REPLACE HELP_TEXT_ID WITH "HT_METADATA_DOCTRINE"
REPLACE OWNER_KIND WITH "concept"
REPLACE OWNER_NAME WITH "METADATA_TRUTH"
REPLACE TEXT_KIND WITH "doctrine"
REPLACE SEQ WITH 20
