# Normalize line endings per INI (auto), keep cross-platform files LF where needed
*           text=auto

# Windows scripts & MSVC project files -> CRLF
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.sln       text eol=crlf
*.vcxproj   text eol=crlf
*.props     text eol=crlf

# Unixy files -> LF (to avoid CI/tooling issues)
*.sh        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Binary files
*.zip       binary
*.exe       binary
*.dll       binary
*.lib       binary
*.pdb       binary
*.dbf       binary
*.inx       binary

# Retained raw runner transcripts (e.g. teed console captures, possibly UTF-16
# with ANSI codes). Treat as binary so no CRLF/encoding normalization can drift
# the SHA-256 that proof ledgers bind (e.g. PINOCCHIO_HISTORICAL_ENGINE_BENCHMARKS).
labtalk/proofs/runs/*.log   binary
