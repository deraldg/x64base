# Apache static hosting for Next.js `out/` export.
# Requires: AllowOverride All (or at least FileInfo, Options) in your vhost.

DirectoryIndex index.html

# Security: deny access to hidden files (except well-known)
<FilesMatch "^\.(?!well-known)">
  Require all denied
</FilesMatch>

# Optional: cache immutable build assets aggressively
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 30 days"
  ExpiresByType application/javascript "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType font/woff2 "access plus 180 days"
</IfModule>

# Optional: enable gzip/brotli if modules are available
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>
